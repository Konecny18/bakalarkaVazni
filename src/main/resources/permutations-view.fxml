<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<!-- Root ScrollPane: allow vertical scrolling when content doesn't fit and fit to width so controls resize horizontally -->
<ScrollPane fx:id="rootScroll" fitToWidth="true" fitToHeight="true" vbarPolicy="AS_NEEDED" hbarPolicy="AS_NEEDED" style="-fx-background-color: #f0f2f5;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="GUI.PermutationsController">
      <VBox alignment="TOP_CENTER" spacing="20.0" style="-fx-background-color: #f0f2f5;" VBox.vgrow="ALWAYS">
         <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
         </padding>

         <VBox spacing="25.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);" VBox.vgrow="NEVER">
            <padding>
               <Insets bottom="30.0" left="40.0" right="40.0" top="30.0" />
            </padding>

            <VBox alignment="CENTER" spacing="5.0">
               <Label style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="Nastavenie simulácie" />
               <Label style="-fx-font-size: 14px; -fx-text-fill: #7f8c8d;" text="Parametre pre výpočet pravdepodobnosti" />
            </VBox>

            <GridPane hgap="15.0" vgap="20.0">
               <columnConstraints>
                  <ColumnConstraints halignment="RIGHT" hgrow="SOMETIMES" minWidth="120.0" />
                  <ColumnConstraints hgrow="ALWAYS" minWidth="200.0" />
               </columnConstraints>
               <rowConstraints>
                  <RowConstraints minHeight="40.0" vgrow="SOMETIMES" />
                  <RowConstraints minHeight="40.0" vgrow="SOMETIMES" />
                  <RowConstraints minHeight="40.0" vgrow="SOMETIMES" />
                  <RowConstraints minHeight="40.0" vgrow="SOMETIMES" />
               </rowConstraints>

               <Label style="-fx-font-weight: bold; -fx-text-fill: #34495e; -fx-font-size: 14px;" text="Počet väzňov:" />
               <TextField fx:id="tfPocetVaznov" maxWidth="300.0" GridPane.columnIndex="1" />

               <Label style="-fx-font-weight: bold; -fx-text-fill: #34495e; -fx-font-size: 14px;" text="Stratégia:" GridPane.rowIndex="1" />
               <ComboBox fx:id="cbStrategie" maxWidth="300.0" GridPane.columnIndex="1" GridPane.rowIndex="1" />

               <Label style="-fx-font-weight: bold; -fx-text-fill: #34495e; -fx-font-size: 14px;" text="Počet simulácií:" GridPane.rowIndex="2" />
               <TextField fx:id="tfPocetPermutacii" maxWidth="300.0" GridPane.columnIndex="1" GridPane.rowIndex="2" />

               <Label style="-fx-font-weight: bold; -fx-text-fill: #34495e; -fx-font-size: 14px;" text="Vylúčiť krabíc:" GridPane.rowIndex="3" />
               <TextField fx:id="tfVylucit" maxWidth="300.0" GridPane.columnIndex="1" GridPane.rowIndex="3" />
               <!-- Inline error message for invalid exclusion input -->
               <Label fx:id="lblVylucitErr" GridPane.columnIndex="1" GridPane.rowIndex="4" text="" wrapText="true" maxWidth="300"
                      style="-fx-text-fill: #e74c3c; -fx-font-size: 12px; -fx-padding: 4 0 0 0;" />
            </GridPane>

            <VBox alignment="CENTER" spacing="15.0">
               <ProgressBar fx:id="progressBar" prefWidth="500.0" progress="0.0" visible="false" />
               <HBox alignment="CENTER" spacing="15.0">
                  <Button fx:id="btnSpustit" onAction="#onSpustiButtonClick" prefHeight="45.0" prefWidth="180.0" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 10;" text="🚀 Spustiť výpočet" />
                  <Button fx:id="btnCancel" onAction="#onCancelButtonClick" prefHeight="45.0" prefWidth="100.0" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 10;" text="STOP" visible="false" />
                  <Button onAction="#onCloseButtonClick" prefHeight="45.0" prefWidth="100.0" style="-fx-background-color: transparent; -fx-border-color: #bdc3c7; -fx-border-radius: 10;" text="Zavrieť" />
               </HBox>
            </VBox>
         </VBox>

         <!-- Results area: allow it to grow and provide an internal ScrollPane for the report text -->
         <VBox fx:id="vboxVysledky" spacing="15.0" minHeight="450.0" prefHeight="450.0" style="-fx-background-color: #f8f9fa; -fx-background-radius: 15; -fx-border-color: #3498db; -fx-border-radius: 15;" VBox.vgrow="ALWAYS">
            <padding>
               <Insets bottom="25.0" left="40.0" right="40.0" top="25.0" />
            </padding>

            <Label style="-fx-font-weight: bold; -fx-font-size: 18px;" text="📊 Výsledky simulácie" />
            <Separator />

            <!-- Replace the report label inside ScrollPane with a non-editable TextArea for proper scrolling -->
            <TextArea fx:id="txtReport" wrapText="true" editable="false" prefRowCount="15" VBox.vgrow="ALWAYS" maxWidth="Infinity" maxHeight="Infinity"
                      prefHeight="380.0" style="-fx-font-family: 'Monospaced'; -fx-font-size: 15px; -fx-background-color: white; -fx-padding: 12;" />

            <HBox alignment="CENTER_RIGHT" spacing="10.0">
               <Button onAction="#onZobrazGrafClick" prefHeight="40.0" prefWidth="160.0" style="-fx-background-color: #2ecc71; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8;" text="Zobraziť grafy" />
               <Button fx:id="btnExportReport" onAction="#onExportReportClick" prefHeight="40.0" prefWidth="160.0" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8;" text="Exportovať report" />
            </HBox>
         </VBox>
      </VBox>
</ScrollPane>