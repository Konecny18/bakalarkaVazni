<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane fitToHeight="true" fitToWidth="true" style="-fx-background-color: #f0f2f5;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="GUI.PermutationsController">
   <content>
      <VBox alignment="TOP_CENTER" spacing="20.0" style="-fx-background-color: #f0f2f5;">
         <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
         </padding>
         <children>
            <VBox spacing="25.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);">
               <padding>
                  <Insets bottom="30.0" left="40.0" right="40.0" top="30.0" />
               </padding>
               <children>
                  <VBox alignment="CENTER" spacing="5.0">
                     <children>
                        <Label style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="Nastavenie simulácie" />
                        <Label style="-fx-font-size: 14px; -fx-text-fill: #7f8c8d;" text="Parametre pre výpočet pravdepodobnosti" />
                     </children>
                  </VBox>

                  <GridPane hgap="15.0" vgap="20.0">
                     <columnConstraints>
                        <ColumnConstraints halignment="RIGHT" hgrow="SOMETIMES" minWidth="120.0" />
                        <ColumnConstraints hgrow="ALWAYS" minWidth="200.0" />
                     </columnConstraints>
                     <children>
                        <Label style="-fx-font-weight: bold;" text="Počet väzňov:" />
                        <TextField fx:id="tfPocetVaznov" maxWidth="300.0" GridPane.columnIndex="1" />

                        <Label style="-fx-font-weight: bold;" text="Stratégia:" GridPane.rowIndex="1" />
                        <ComboBox fx:id="cbStrategie" maxWidth="300.0" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                        <Label style="-fx-font-weight: bold;" text="Počet simulácií:" GridPane.rowIndex="2" />
                        <TextField fx:id="tfPocetPermutacii" maxWidth="300.0" GridPane.columnIndex="1" GridPane.rowIndex="2" />

                        <Label style="-fx-font-weight: bold;" text="Vylúčiť krabíc:" GridPane.rowIndex="3" />
                        <TextField fx:id="tfVylucit" maxWidth="300.0" GridPane.columnIndex="1" GridPane.rowIndex="3" />
                     </children>
                  </GridPane>

                  <VBox alignment="CENTER" spacing="15.0">
                     <children>
                        <ProgressBar fx:id="progressBar" prefWidth="500.0" progress="0.0" visible="false" />
                        <HBox alignment="CENTER" spacing="15.0">
                           <children>
                              <Button fx:id="btnSpustit" onAction="#onSpustiButtonClick" prefHeight="45.0" prefWidth="180.0" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 10;" text="🚀 Spustiť výpočet" />
                              <Button fx:id="btnCancel" onAction="#onCancelButtonClick" prefHeight="45.0" prefWidth="100.0" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 10;" text="STOP" visible="false" />
                              <Button onAction="#onCloseButtonClick" prefHeight="45.0" prefWidth="100.0" style="-fx-background-color: transparent; -fx-border-color: #bdc3c7; -fx-border-radius: 10;" text="Zavrieť" />
                           </children>
                        </HBox>
                     </children>
                  </VBox>
               </children>
            </VBox>

            <VBox fx:id="vboxVysledky" spacing="15.0" style="-fx-background-color: #f8f9fa; -fx-background-radius: 15; -fx-border-color: #3498db; -fx-border-radius: 15;">
               <padding>
                  <Insets bottom="25.0" left="40.0" right="40.0" top="25.0" />
               </padding>
               <children>
                  <Label style="-fx-font-weight: bold; -fx-font-size: 18px;" text="📊 Výsledky simulácie" />
                  <Separator />
                  <Label fx:id="lblReport" maxWidth="Infinity" style="-fx-font-family: 'Monospaced'; -fx-font-size: 14px; -fx-background-color: white; -fx-padding: 15;" wrapText="true" />
                  <HBox alignment="CENTER_RIGHT">
                     <children>
                        <Button onAction="#onZobrazGrafClick" prefHeight="40.0" prefWidth="180.0" style="-fx-background-color: #2ecc71; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8;" text="Zobraziť grafy" />
                     </children>
                  </HBox>
               </children>
            </VBox>
         </children>
      </VBox>
   </content>
</ScrollPane>