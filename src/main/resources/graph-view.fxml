<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.chart.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="GUI.GraphController" prefWidth="900.0" prefHeight="700.0" style="-fx-background-color: white;">
    <center>
        <VBox spacing="20.0" alignment="CENTER">
            <padding>
                <Insets top="20" right="20" bottom="20" left="20" />
            </padding>
            <children>
                <HBox spacing="30.0" alignment="CENTER" VBox.vgrow="SOMETIMES">
                    <children>
                        <VBox alignment="CENTER" spacing="10.0" HBox.hgrow="ALWAYS">
                            <children>
                                <Label fx:id="lblSimTitle" style="-fx-font-size: 16px; -fx-font-weight: bold;" text="Výsledok simulácie" />
                                <PieChart fx:id="pieSimulation" legendSide="BOTTOM" />
                            </children>
                        </VBox>
                        <VBox alignment="CENTER" spacing="10.0" HBox.hgrow="ALWAYS">
                            <children>
                                <Label fx:id="lblTheoryTitle" style="-fx-font-size: 16px; -fx-font-weight: bold;" text="Teoretická hodnota" />
                                <PieChart fx:id="pieTheory" legendSide="BOTTOM" />
                            </children>
                        </VBox>
                    </children>
                </HBox>

                <Separator />

                <HBox spacing="20.0" alignment="CENTER" VBox.vgrow="ALWAYS">
                    <children>
                        <VBox spacing="10.0" alignment="CENTER_LEFT" HBox.hgrow="ALWAYS">
                            <children>
                                <Label text="Distribúcia úspešných väzňov (histogram)" style="-fx-font-weight: bold; -fx-font-size: 14px;" />
                                <BarChart fx:id="histogram" animated="false" legendVisible="false">
                                    <xAxis>
                                        <CategoryAxis label="Počet úspešných väzňov" />
                                    </xAxis>
                                    <yAxis>
                                        <NumberAxis label="Frekvencia" />
                                    </yAxis>
                                </BarChart>
                            </children>
                        </VBox>

                        <VBox fx:id="statsBox" minWidth="220.0" spacing="12.0" alignment="CENTER_LEFT" style="-fx-background-color: #f8f9fa; -fx-padding: 20; -fx-background-radius: 10; -fx-border-color: #dee2e6; -fx-border-radius: 10;">
                            <children>
                                <Label text="Súhrnné štatistiky" style="-fx-font-weight: bold; -fx-font-size: 15px; -fx-text-fill: #2c3e50;" />
                                <Separator />
                                <Label fx:id="lblTotalRuns" text="Simulácií: -" />
                                <Label fx:id="lblMean" text="Priemer: -" />
                                <Label fx:id="lblStdDev" text="Št. odchýlka: -" />
                                <Label fx:id="lblMedian" text="Medián: -" />
                                <Label fx:id="lblMax" text="Max úspechov: -" />
                            </children>
                        </VBox>
                    </children>
                </HBox>
            </children>
        </VBox>
    </center>
    <bottom>
        <HBox alignment="CENTER" prefHeight="60.0" style="-fx-background-color: #f1f3f5;">
            <children>
                <Button text="Zavrieť okno" onAction="#onClose" prefWidth="120.0" style="-fx-background-radius: 5;" />
            </children>
        </HBox>
    </bottom>
</BorderPane>