<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<HBox spacing="15.0" prefHeight="750.0" prefWidth="1100.0" style="-fx-background-color: #f4f7f9;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="GUI.ExplainController">
    <padding>
        <Insets bottom="15.0" left="15.0" right="15.0" top="15.0"/>
    </padding>

    <VBox spacing="15.0" prefWidth="420.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 0);">
        <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
        </padding>

        <Label text="Vizuálny sprievodca stratégiami" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>

        <Separator/>

        <Label text="Vyberte stratégiu:" style="-fx-font-weight: bold;"/>
        <ComboBox fx:id="cbStrategieExplain" onAction="#onStrategiaChanged" prefWidth="Infinity" style="-fx-background-radius: 5;"/>

        <Label text="Teoretický princíp:" style="-fx-font-weight: bold;"/>
        <TextArea fx:id="txtVysvetlenie" editable="false" wrapText="true" VBox.vgrow="ALWAYS"
                  style="-fx-font-family: 'Segoe UI'; -fx-font-size: 13px; -fx-control-inner-background: #fdfdfd;"/>

        <Label text="Analýza aktuálneho rozloženia:" style="-fx-font-weight: bold;"/>
        <TextArea fx:id="txtAreaCykly" editable="false" prefHeight="150.0"
                  style="-fx-font-family: 'Monospaced'; -fx-font-size: 12px; -fx-control-inner-background: #f8f9fa;"/>

        <Button text="🔄 Generovať novú permutáciu" onAction="#generujNovuMapu" maxWidth="Infinity"
                style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5; -fx-cursor: hand;"/>
    </VBox>

    <VBox spacing="15.0" alignment="CENTER" HBox.hgrow="ALWAYS" style="-fx-background-color: white; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 0);">
        <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
        </padding>

        <Label fx:id="lblStatus" text="Status" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>

        <StackPane VBox.vgrow="ALWAYS" style="-fx-background-color: #fafafa; -fx-border-color: #ecf0f1; -fx-border-radius: 5;">
            <GridPane fx:id="paneKrabice" alignment="CENTER" hgap="4.0" vgap="4.0">
                <padding>
                    <Insets bottom="10.0" left="10.0" right="10.0" top="10.0"/>
                </padding>
            </GridPane>
        </StackPane>

        <HBox alignment="CENTER" spacing="20.0" style="-fx-background-color: #f8f9fa; -fx-padding: 10; -fx-background-radius: 5;">
                <Label fx:id="lblInfo" text="Kliknite na krabicu pre zobrazenie obsahu" style="-fx-font-style: italic;"/>
        </HBox>

        <Button text="Zavrieť okno" onAction="#onClose" prefWidth="150.0"
                style="-fx-background-color: #95a5a6; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5;"/>
    </VBox>
</HBox>